{
  "name": "moon",
  "private": true,
  "packageManager": "yarn@4.16.0",
  "scripts": {
    "moon": "target/debug/moon --log trace",
    "type": "target/debug/moon --log trace run :typecheck",
    "clean": "rm -rf packages/*/{cjs,dist,dts,tsconfig.*.tsbuildinfo}",
    "build:types": "cd packages/types && NODE_ENV=production vp pack"
  },
  "workspaces": [
    "packages/*",
    "scenarios/*",
    "website"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "execa": "^6.1.0",
    "globals": "^17.6.0",
    "tsconfig-moon": "^1.4.2",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "^4.1.8"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
